# YARN 드라이버에 배포되는 .env (--files로 전달)

VAULT__URL=http://vault.svc.internal:8200
VAULT__USERNAME=<user-rw role_id>
VAULT__PASSWORD=<user-rw secret_id>
VAULT__SECRET_PATH=kv-personal/data/local/database/mysql

DATABASE__TYPE=mysql

STORAGE__PROFILE=default
STORAGE__CATALOG=awsdatacatalog
STORAGE__CATALOG_TYPE=glue
STORAGE__BUCKET=blueriver-datalake
STORAGE__DATA_PATH=/iceberg

KAFKA__BOOTSTRAP_SERVERS=kafka.svc.internal:9092
KAFKA__SCHEMA_REGISTRY=http://schema-registry.svc.internal:8081
KAFKA__METRIC_NAMESPACE=metric_namespace
KAFKA__MAX_OFFSETS_PER_TRIGGER=1000000
KAFKA__STARTING_OFFSETS=earliest
